POSTGRES_DB=enderchest
POSTGRES_USER=enderchest_user
POSTGRES_PASSWORD=replace_me

MINIO_ROOT_USER=replace_me
MINIO_ROOT_PASSWORD=replace_me

# Used only when no admin account exists yet.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace_me_with_a_long_password

# Default invite expiration in hours when not specified in the request.
INVITE_DEFAULT_EXPIRES_HOURS=24

# 10 GiB per newly registered user.
DEFAULT_QUOTA_BYTES=10737418240

# Optional security defaults.
PASSWORD_MIN_LENGTH=12
PASSWORD_MAX_LENGTH=128

LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MS=600000
LOGIN_RATE_LIMIT_BLOCK_MS=900000

REGISTER_RATE_LIMIT_MAX=5
REGISTER_RATE_LIMIT_WINDOW_MS=1800000
REGISTER_RATE_LIMIT_BLOCK_MS=1800000

INVITE_RATE_LIMIT_MAX=10
INVITE_RATE_LIMIT_WINDOW_MS=3600000
INVITE_RATE_LIMIT_BLOCK_MS=3600000

# Upload guardrail (bytes).
MAX_UPLOAD_BYTES=52428800
